{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/go/springwell-ss",
      "destination": "https://www.springwellwater.com/product/water-softeners/salt-water-softeners/?affid=40&oid=9",
      "permanent": false
    },
    {
      "source": "/go/springwell-futuresoft",
      "destination": "https://www.springwellwater.com/product/water-softeners/salt-free-water-softeners/?affid=40&oid=2",
      "permanent": false
    },
    {
      "source": "/go/springwell-combo-salt",
      "destination": "https://www.springwellwater.com/product/dual-systems/water-filter-salt-softener/?affid=40&oid=10",
      "permanent": false
    },
    {
      "source": "/go/springwell-combo-saltfree",
      "destination": "https://www.springwellwater.com/product/dual-systems/2-in-1-filter-salt-softener-combo-system/?affid=40&oid=4",
      "permanent": false
    },
    {
      "source": "/go/test-kit",
      "destination": "https://www.springwellwater.com/product-category/water-filters/?affid=40&oid=8",
      "permanent": false
    },
    {
      "source": "/go/replacement-prefilters",
      "destination": "https://www.springwellwater.com/product-category/replacements/?affid=40&oid=26",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/embed/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/go/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
